#!/bin/bash

# Kill the session if it already exists so we always start fresh
tmux kill-session -t forge_swarm 2>/dev/null

# 1. Create a new detached tmux session named "forge_swarm"
tmux new-session -d -s forge_swarm

# 2. Pane 0 (Top-Left): Agent 1 in Text Mode
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_1' -p 'What tools do you have? Store detailed descriptions in a database, include embedding for later semantic search. What tool is most similar to a word \"research\"? What tools could you build? Brainstorm with adviser to know what your options are. Write the outcome to a markdown formatted file.'" C-m

# 3. Pane 1 (Top-Right): Agent 2 in Text Mode
tmux split-window -h -t forge_swarm
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_2' -p 'What is the address of this GPS coordinates: 42.3584, -71.0598? Write the answer to a file. Explain the tools that you had to forge. Ask adviser for feedback for how to generate a table with current weather at 50 random locations on the planet. Execute the plan, collect data and write a report to a markdown formatted file.'" C-m

# 4. Pane 2 (Bottom-Left): Agent 3 in MD Mode (Splits the top-left pane)
tmux split-window -v -t forge_swarm:0.0
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_3' -p 'What are the files and folders available in your environment? Make a plan how to explore as far as you can. Export the list to a text file. At the end write a memory of this and clear your history.'" C-m

# 5. Pane 3 (Bottom-Right): Agent 4 in MD Mode (Splits the top-right pane)
tmux split-window -v -t forge_swarm:0.2
tmux send-keys -t forge_swarm "pixi run python chat_overseer.py -x -f formatted -s 'Agent_4' -p 'What is the T6SS? Read wiki, and search the web. Make a plan for finding 30 most recent papers in the T6SS field. Store their titles and abstracts into a database (no embedding needed). By full-text search, find the papers that mention \"effector\" in their abstract. Save the titles and abstracts to a markdown formatted file.'" C-m

# 6. Balance the panes into a perfect 2x2 grid
tmux select-layout -t forge_swarm tiled

# 7. Attach to watch your swarm wake up!
tmux attach-session -t forge_swarm
